# CortexGate Environment Configuration
# Copy this file to .env and replace the placeholders with your actual secrets.

# MongoDB configuration
MONGO_PASSWORD=your_secure_mongodb_password

# PostgreSQL configuration
POSTGRES_PASSWORD=your_secure_postgres_password

# Gemini API Key (OpenAI compatible endpoint used via Spring AI)
GEMINI_API_KEY=your_gemini_api_key_here
